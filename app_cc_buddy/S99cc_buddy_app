#!/bin/sh
### BEGIN INIT INFO
# Provides:          cc_buddy_app
# Required-Start:    $local_fs $network
# Required-Stop:     $local_fs $network
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
# Short-Description: Start CC Buddy app
### END INIT INFO

APP_DIR="/opt/app_cc_buddy"
APP_ENTRY="main.py"
PYTHON_BIN="/usr/bin/python3"
PID_FILE="/var/run/cc_buddy_app.pid"
LOG_FILE="/var/log/cc_buddy_app.log"
MAX_LOG_SIZE=2097152

export LOG_LEVEL="${LOG_LEVEL:-WARNING}"

start() {
    echo "Starting cc_buddy_app..."

    if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        echo "cc_buddy_app is already running (pid $(cat "$PID_FILE"))"
        return 0
    fi

    mkdir -p "$(dirname "$PID_FILE")" "$(dirname "$LOG_FILE")"
    cd "$APP_DIR" || {
        echo "Cannot cd to $APP_DIR"
        return 1
    }

    if [ -f "$LOG_FILE" ]; then
        log_size=$(wc -c < "$LOG_FILE" 2>/dev/null || echo 0)
        if [ "$log_size" -gt "$MAX_LOG_SIZE" ]; then
            rm -f "$LOG_FILE"
        fi
    fi

    nohup "$PYTHON_BIN" "$APP_DIR/$APP_ENTRY" >> "$LOG_FILE" 2>&1 &
    echo $! > "$PID_FILE"

    sleep 1
    if kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        echo "cc_buddy_app started (pid $(cat "$PID_FILE"))"
        return 0
    else
        echo "cc_buddy_app failed to start"
        rm -f "$PID_FILE"
        return 1
    fi
}

stop() {
    echo "Stopping cc_buddy_app..."

    if [ ! -f "$PID_FILE" ]; then
        echo "pid file not found, maybe cc_buddy_app not running"
        return 0
    fi

    PID="$(cat "$PID_FILE")"
    if kill -0 "$PID" 2>/dev/null; then
        kill "$PID"
        sleep 1
        if kill -0 "$PID" 2>/dev/null; then
            echo "force killing $PID"
            kill -9 "$PID"
        fi
        echo "cc_buddy_app stopped"
    else
        echo "process $PID not running"
    fi

    rm -f "$PID_FILE"
}

status() {
    if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        echo "cc_buddy_app is running (pid $(cat "$PID_FILE"))"
        return 0
    fi
    echo "cc_buddy_app is not running"
    return 3
}

case "$1" in
    start)
        start
        ;;
    stop)
        stop
        ;;
    restart)
        stop
        start
        ;;
    status)
        status
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status}"
        exit 1
        ;;
esac

exit 0
